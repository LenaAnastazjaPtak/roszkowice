<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logowanie · Pałac Roszkowice Admin</title>
    <link rel="icon" href="/images/roszkowice/logo_with_transparent_background.png">
    <style>
        :root {
            --brand-primary: #c19a6b;
            --brand-bg: #f6f1ea;
            --brand-card: #ffffff;
            --brand-text: #2a2520;
            --brand-muted: #8a7a66;
            --brand-error: #b54c4c;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            background: var(--brand-bg);
            color: var(--brand-text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .card {
            background: var(--brand-card);
            border-radius: 12px;
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
            padding: 40px;
            width: 100%;
            max-width: 420px;
        }
        .logo {
            display: block;
            margin: 0 auto 24px;
            width: 96px;
            height: auto;
        }
        h1 {
            margin: 0 0 8px;
            font-size: 24px;
            text-align: center;
        }
        .subtitle {
            margin: 0 0 28px;
            text-align: center;
            color: var(--brand-muted);
            font-size: 14px;
        }
        label {
            display: block;
            font-size: 13px;
            margin-bottom: 6px;
            color: var(--brand-text);
        }
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #d8cdb8;
            border-radius: 6px;
            font-size: 15px;
            margin-bottom: 16px;
            background: #fafafa;
        }
        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: var(--brand-primary);
            background: #ffffff;
        }
        button {
            width: 100%;
            padding: 12px;
            background: var(--brand-primary);
            color: #ffffff;
            border: 0;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
        }
        button:hover { filter: brightness(0.95); }
        .error {
            background: #fbe9e9;
            border: 1px solid #f0c6c6;
            color: var(--brand-error);
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 16px;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <main class="card">
        <img class="logo" src="/images/roszkowice/logo_admin_128.png" alt="Pałac Roszkowice" onerror="this.style.display='none'">
        <h1>Pałac Roszkowice</h1>
        <p class="subtitle">Panel administracyjny</p>

        {% if error %}
            <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="{{ last_username }}" autocomplete="email" required autofocus>

            <label for="password">Hasło</label>
            <input type="password" id="password" name="password" autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit">Zaloguj się</button>
        </form>
    </main>
</body>
</html>
