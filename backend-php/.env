# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8000
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL=mysql://user:password@127.0.0.1:3306/roszkowice_php?serverVersion=mariadb-10.11.0&charset=utf8mb4
###< doctrine/doctrine-bundle ###

###> app/admin ###
ADMIN_EMAIL=
ADMIN_PASSWORD=
###< app/admin ###

###> app/legacy-import ###
LEGACY_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/roszkowice?serverVersion=16&charset=utf8
###< app/legacy-import ###

###> app/frontend-images ###
FRONTEND_IMAGES_DIR=%kernel.project_dir%/../app/public/images
###< app/frontend-images ###
